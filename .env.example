# ── Runtime env vars ──────────────────────────────────────────────────────────
# Injected by the platform at container start time.
# Set these in APD-Deploy → app → Config tab, then redeploy.

APP_GREETING=Hello
APP_NAME=World
APP_COLOR=blue

# ── Build-time args (Dockerfile ARG) ─────────────────────────────────────────
# Consumed during `docker build` — NOT available at container runtime.
# Pass via CI/CD pipeline or: docker build --build-arg APP_VERSION=1.0.0
#
# APP_VERSION=1.0.0
# BUILD_DATE=2025-05-29
# GIT_COMMIT=abc1234
