# ─── Runtime environment variables ───────────────────────────────────────────
# Injected by the platform into the running container at deploy time.
# Set these in the APD-Deploy → Config tab before deploying.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/testdb

# Database connection pool (optional — defaults shown)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL_ENABLED=false

# JWT authentication
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=another-long-random-string-different-from-above
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://myapp.swiftoffice.org,http://localhost:3000

# Redis (session / cache)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=300

# External API
EXTERNAL_API_BASE_URL=https://api.partner.gov.sg
EXTERNAL_API_KEY=your-api-key-here
EXTERNAL_API_TIMEOUT_MS=5000

# SMTP / email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_ADDRESS=noreply@example.com

# Feature flags
FEATURE_ENABLE_REGISTRATION=false
FEATURE_MAINTENANCE_MODE=false

# Observability
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
APP_LOG_LEVEL=info

# ─── Build-time variables ─────────────────────────────────────────────────────
# Consumed during `docker build`. NOT available at container runtime.
# Pass via `docker build --build-arg VAR=value` or set in CI/CD pipeline vars.
#
# APP_VERSION=1.0.0
# BUILD_TARGET=production
# SENTRY_AUTH_TOKEN=sntrys_xxx   # uploads source maps during build
# NPM_TOKEN=npm_xxx              # pulls private packages from npm registry
